                <SubtypeId>RailgunTurret</SubtypeId>
            </Id>
            <DefaultComponents>
                <Component BuilderType="MyObjectBuilder_Inventory" SubtypeId="AmmoFilterLargeRailgun" ForceCreate="true"/>
            </DefaultComponents>
        </Container>
        <Container>
